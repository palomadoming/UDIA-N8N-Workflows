    {
      "parameters": {
        "jsCode": "const texto = items[0].json.text;\nconst chunkSize = 500;\nconst overlap = 50;\nconst palabras = texto.split(' ');\nconst chunks = [];\n\nfor (let i = 0; i < palabras.length; i += chunkSize - overlap) {\n  const chunk = palabras.slice(i, i + chunkSize).join(' ');\n  if (chunk.trim()) {\n    chunks.push({\n      json: {\n        contenido: chunk,\n        metadata: { pagina_aprox: Math.floor(i / chunkSize) + 1 }\n      }\n    });\n  }\n}\n\nreturn chunks;"
      },
