    {
      "parameters": {
        "jsCode": "// Obtenemos todos los ítems que llegan al nodo\nconst allItems = $input.all();\n\n// Fusionamos todos los objetos internos en uno solo\nconst mergedData = allItems.reduce((acc, item) => {\n  return { ...acc, ...item.json };\n}, {});\n\n// Devolvemos el resultado envuelto en la estructura que n8n espera\nreturn { json: mergedData };"
